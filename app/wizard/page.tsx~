// app/wizard/page.tsx
"use client";
import { useState } from "react";
import { useForm } from "react-hook-form";

export default function Wizard() {
  const [step, setStep] = useState(1);
  const { register, handleSubmit, watch, setValue } = useForm({
    defaultValues: { template: 1, businessName: '', heroText: '' }
  });

  const selectedTemplate = watch("template");

  const onSubmit = async (data: any) => {
    // In production, this posts to your API
    console.log("Generating site with data:", data);
    
    // Mocking the API response and redirect
    alert(`Site generated! Redirecting to preview...`);
    window.location.href = `/site/mock-id-123`; 
  };

  return (
    <div className="min-h-screen bg-neutral-900 text-white flex items-center justify-center p-8">
      <div className="max-w-2xl w-full bg-neutral-800 p-8 rounded-2xl shadow-2xl">
        <h1 className="text-3xl font-bold mb-8">Landscaper Site Wizard</h1>
        
        <form onSubmit={handleSubmit(onSubmit)}>
          {step === 1 && (
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              {[1, 2, 3].map(t => (
                <div 
                  key={t} 
                  onClick={() => setValue("template", t)}
                  className={`p-6 border-2 cursor-pointer rounded-xl transition-all ${
                    selectedTemplate === t ? 'border-green-500 bg-green-500/10' : 'border-neutral-700 hover:border-neutral-500'
                  }`}
                >
                  <p className="font-bold">Template {t}</p>
                  {t === 1 && <span className="text-xs text-green-400 mt-2 block">Award Winner (Cinematic)</span>}
                </div>
              ))}
              <button 
                type="button" 
                onClick={() => setStep(2)} 
                className="col-span-1 md:col-span-3 bg-white text-black p-4 mt-4 rounded-lg font-bold hover:bg-neutral-200"
              >
                Next Step
              </button>
            </div>
          )}

          {step === 2 && (
            <div className="flex flex-col gap-4">
              <input 
                {...register("businessName", { required: true })}
                type="text" 
                placeholder="Business Name (e.g., Apex Landscaping)" 
                className="p-4 bg-neutral-700 rounded-lg outline-none focus:ring-2 focus:ring-green-500"
              />
              <input 
                {...register("heroText", { required: true })}
                type="text" 
                placeholder="Hero Catchphrase (e.g., Nature, Redefined.)" 
                className="p-4 bg-neutral-700 rounded-lg outline-none focus:ring-2 focus:ring-green-500"
              />
              
              <div className="flex gap-4 mt-4">
                <button 
                  type="button" 
                  onClick={() => setStep(1)} 
                  className="bg-neutral-600 text-white p-4 rounded-lg font-bold flex-1 hover:bg-neutral-500"
                >
                  Back
                </button>
                <button 
                  type="submit" 
                  className="bg-green-500 text-white p-4 rounded-lg font-bold flex-[2] hover:bg-green-400"
                >
                  Generate Site
                </button>
              </div>
            </div>
          )}
        </form>
      </div>
    </div>
  );
}